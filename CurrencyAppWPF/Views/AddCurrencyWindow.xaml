<Window x:Class="CurrencyAppWPF.AddCurrencyWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавить валюту" Height="450" Width="400"
        WindowStartupLocation="CenterOwner">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Код валюты (например: BTC)" FontWeight="Bold" Margin="0,5"/>
        <TextBox Grid.Row="1" Text="{Binding CharCode, UpdateSourceTrigger=PropertyChanged}" Margin="0,5" Padding="5"/>

        <TextBlock Grid.Row="2" Text="Название валюты" FontWeight="Bold" Margin="0,5"/>
        <TextBox Grid.Row="3" Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}" Margin="0,5" Padding="5"/>

        <TextBlock Grid.Row="4" Text="Курс к рублю" FontWeight="Bold" Margin="0,5"/>
        <TextBox Grid.Row="5" Text="{Binding Value, UpdateSourceTrigger=PropertyChanged}" Margin="0,5" Padding="5"/>

        <TextBlock Grid.Row="6" Text="Пример: 100.50" Foreground="Gray" Margin="0,5"/>

        <TextBlock Grid.Row="7" Text="{Binding ErrorMessage}" Foreground="Red" Margin="0,5"/>

        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,20">
            <Button Content="Добавить" Command="{Binding AddCommand}" 
                    Background="Green" Foreground="White" 
                    Padding="20,8" Margin="5"/>
            <Button Content="Отмена" Command="{Binding CancelCommand}" 
                    Padding="20,8" Margin="5"/>
        </StackPanel>
    </Grid>
</Window>